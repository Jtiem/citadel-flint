{
  "$schema": "https://tr.designtokens.org/format/",
  "color": {
    "brand": {
      "primary": { "$value": "#1a56db", "$type": "color" },
      "secondary": { "$value": "#6875f5", "$type": "color" },
      "accent": { "$value": "#0e9f6e", "$type": "color" }
    },
    "neutral": {
      "900": { "$value": "#111928", "$type": "color" },
      "700": { "$value": "#374151", "$type": "color" },
      "200": { "$value": "#e5e7eb", "$type": "color" }
    },
    "feedback": {
      "error": { "$value": "#f05252", "$type": "color" },
      "success": { "$value": "#0e9f6e", "$type": "color" }
    }
  },
  "spacing": {
    "sm": { "$value": "8px", "$type": "dimension" },
    "md": { "$value": "16px", "$type": "dimension" },
    "lg": { "$value": "24px", "$type": "dimension" }
  },
  "typography": {
    "size": {
      "sm": { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "lg": { "$value": "20px", "$type": "dimension" },
      "xl": { "$value": "24px", "$type": "dimension" }
    },
    "weight": {
      "regular": { "$value": "400", "$type": "fontWeight" },
      "medium": { "$value": "500", "$type": "fontWeight" },
      "bold": { "$value": "700", "$type": "fontWeight" }
    }
  }
}
