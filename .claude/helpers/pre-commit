#!/bin/bash
# Bridge Pre-Commit Hook
# Enforces TypeScript type checking before any commit is allowed.
# Bypass with: git commit --no-verify

set -e

ROOT_DIR="$(git rev-parse --show-toplevel)"

echo ""
echo "=== Flint Pre-Commit Gate ==="
echo ""

FAILED=0

# --- Step 1: Root project TSC ---
echo "[1/2] Type-checking root project..."
if (cd "$ROOT_DIR" && npx tsc --noEmit 2>&1); then
  echo "      Root project: PASS"
else
  echo ""
  echo "      Root project: FAIL"
  FAILED=1
fi

echo ""

# --- Step 2: flint-mcp TSC ---
echo "[2/2] Type-checking flint-mcp..."
if (cd "$ROOT_DIR" && npx tsc --noEmit --project "$ROOT_DIR/flint-mcp/tsconfig.json" 2>&1); then
  echo "      flint-mcp: PASS"
else
  echo ""
  echo "      flint-mcp: FAIL"
  FAILED=1
fi

echo ""

# --- Gate decision ---
if [ $FAILED -ne 0 ]; then
  echo "=== COMMIT BLOCKED ==="
  echo ""
  echo "TypeScript type errors must be fixed before committing."
  echo "Fix the errors above, then try again."
  echo ""
  echo "To bypass this check (use sparingly):"
  echo "  git commit --no-verify"
  echo ""
  exit 1
fi

echo "=== All checks passed ==="
echo ""
