{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flint MCP Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["flint-mcp/dist/cli.js", "serve"]
    },
    {
      "name": "Figma Ingestion Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["flint-mcp/dist/core/ingestion/server.js"],
      "port": 4545
    },
    {
      "name": "Vitest (Watch)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vitest", "--watch", "--config", "flint-mcp/vitest.config.ts"]
    }
    ,
    {
      "name": "Flint Website",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "website"],
      "port": 5173
    },
    {
      "name": "Demo Preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--config", "demos/vite.config.ts"],
      "port": 5174
    }
  ]
}
