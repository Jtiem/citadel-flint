{
    "version": 1,
    "mithril": {
        "deltaE_threshold": 2,
        "deltaE_critical_threshold": 10,
        "mode": "blocking",
        "ignore_patterns": [
            "**/node_modules/**"
        ]
    },
    "a11y": {
        "level": "AA",
        "mode": "blocking",
        "disabled_rules": []
    },
    "export_gate": {
        "block_on_mithril": true,
        "block_on_a11y": true,
        "block_on_overrides": true
    },
    "baseline": {
        "enabled": false
    }
}
