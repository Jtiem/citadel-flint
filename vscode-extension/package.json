{
  "name": "flint-governance",
  "displayName": "Flint Governance",
  "description": "Design system governance, accessibility, and token compliance for UI code",
  "version": "0.1.0",
  "publisher": "flint-dev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "workspaceContains:flint-manifest.json",
    "workspaceContains:.flint/"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flint.auditFile",
        "title": "Flint: Audit Current File"
      },
      {
        "command": "flint.auditWorkspace",
        "title": "Flint: Audit Workspace"
      },
      {
        "command": "flint.fixFile",
        "title": "Flint: Fix Current File"
      }
    ],
    "configuration": {
      "title": "Flint Governance",
      "properties": {
        "flint.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Flint governance audits."
        },
        "flint.auditOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically run Flint audit when a file is saved."
        },
        "flint.deltaEThreshold": {
          "type": "number",
          "default": 2.0,
          "description": "CIEDE2000 Delta-E threshold for color drift detection."
        },
        "flint.conformanceLevel": {
          "type": "string",
          "default": "AA",
          "enum": ["A", "AA", "AAA"],
          "description": "WCAG conformance level for accessibility audits."
        },
        "flint.serverPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to flint-mcp/dist/server.js. Leave empty to auto-detect."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
