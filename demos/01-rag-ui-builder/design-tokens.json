{
  "$schema": "https://tr.designtokens.org/format/",
  "color": {
    "primary": {
      "$type": "color",
      "$value": "#0066FF",
      "$description": "Primary brand blue — interactive elements, CTAs, focus rings"
    },
    "primary-hover": {
      "$type": "color",
      "$value": "#0052CC",
      "$description": "Primary blue darkened 20% for hover states"
    },
    "primary-subtle": {
      "$type": "color",
      "$value": "#E5EEFF",
      "$description": "10% primary blue tint — hover backgrounds, chips"
    },
    "surface": {
      "$type": "color",
      "$value": "#FFFFFF",
      "$description": "Default page and card surface"
    },
    "surface-raised": {
      "$type": "color",
      "$value": "#F8F9FA",
      "$description": "Slightly elevated surface — sidebars, panels"
    },
    "on-surface": {
      "$type": "color",
      "$value": "#111827",
      "$description": "Primary text on light surface"
    },
    "on-surface-muted": {
      "$type": "color",
      "$value": "#6B7280",
      "$description": "Secondary / helper text"
    },
    "on-primary": {
      "$type": "color",
      "$value": "#FFFFFF",
      "$description": "Text/icons on primary-color backgrounds"
    },
    "border": {
      "$type": "color",
      "$value": "#E5E7EB",
      "$description": "Subtle dividers and input borders"
    }
  },
  "spacing": {
    "1": {
      "$type": "dimension",
      "$value": "4px",
      "$description": "Smallest spacing unit"
    },
    "2": {
      "$type": "dimension",
      "$value": "8px",
      "$description": "Compact spacing"
    },
    "3": {
      "$type": "dimension",
      "$value": "12px",
      "$description": "CTA vertical padding"
    },
    "4": {
      "$type": "dimension",
      "$value": "16px",
      "$description": "Standard component padding / gap"
    },
    "6": {
      "$type": "dimension",
      "$value": "24px",
      "$description": "Card / panel padding / CTA horizontal padding"
    },
    "12": {
      "$type": "dimension",
      "$value": "48px",
      "$description": "Banner interior padding"
    }
  },
  "radius": {
    "sm": {
      "$type": "dimension",
      "$value": "8px",
      "$description": "Button / input radius"
    },
    "md": {
      "$type": "dimension",
      "$value": "12px",
      "$description": "Card / banner radius"
    }
  },
  "fontSize": {
    "xs": {
      "$type": "dimension",
      "$value": "12px",
      "$description": "Uppercase label text"
    },
    "sm": {
      "$type": "dimension",
      "$value": "14px",
      "$description": "Secondary UI / CTA label"
    },
    "base": {
      "$type": "dimension",
      "$value": "16px",
      "$description": "Default body copy"
    },
    "lg": {
      "$type": "dimension",
      "$value": "20px",
      "$description": "Sub-headings and card titles"
    },
    "xl": {
      "$type": "dimension",
      "$value": "24px",
      "$description": "Banner headlines"
    },
    "cta": {
      "$type": "dimension",
      "$value": "{fontSize.sm}",
      "$description": "CTA button label — alias of fontSize.sm (demonstrates adapter alias resolution)"
    },
    "broken-alias": {
      "$type": "dimension",
      "$value": "{fontSize.nonexistent}",
      "$description": "Intentionally broken alias — exercises ALIAS_BROKEN_REF error path in live audits"
    }
  }
}
