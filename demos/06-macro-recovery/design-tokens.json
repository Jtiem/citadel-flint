{
  "$schema": "https://tr.designtokens.org/format/",
  "color": {
    "surface": {
      "$type": "color",
      "$value": "#FFFFFF",
      "$description": "Card surface (bg-white)"
    },
    "surface-muted": {
      "$type": "color",
      "$value": "#F9FAFB",
      "$description": "Footer surface (bg-gray-50)"
    },
    "border": {
      "$type": "color",
      "$value": "#E5E7EB",
      "$description": "Card border (border-gray-200)"
    },
    "border-subtle": {
      "$type": "color",
      "$value": "#F3F4F6",
      "$description": "Section divider (border-gray-100)"
    },
    "text-primary": {
      "$type": "color",
      "$value": "#111827",
      "$description": "Primary text"
    },
    "text-secondary": {
      "$type": "color",
      "$value": "#4B5563",
      "$description": "Secondary text (text-gray-600)"
    },
    "text-muted": {
      "$type": "color",
      "$value": "#6B7280",
      "$description": "Helper text (text-gray-500)"
    },
    "primary": {
      "$type": "color",
      "$value": "#2563EB",
      "$description": "Brand link (text-blue-600)"
    },
    "primary-subtle": {
      "$type": "color",
      "$value": "#EFF6FF",
      "$description": "Topic chip background (bg-blue-50)"
    },
    "success": {
      "$type": "color",
      "$value": "#15803D",
      "$description": "Public badge text (text-green-700)"
    },
    "success-subtle": {
      "$type": "color",
      "$value": "#F0FDF4",
      "$description": "Public badge background (bg-green-50)"
    }
  },
  "spacing": {
    "1": { "$type": "dimension", "$value": "4px", "$description": "Hairline spacing" },
    "2": { "$type": "dimension", "$value": "8px", "$description": "Compact gap" },
    "3": { "$type": "dimension", "$value": "12px", "$description": "Standard gap" },
    "4": { "$type": "dimension", "$value": "16px", "$description": "Section padding" },
    "5": { "$type": "dimension", "$value": "20px", "$description": "Card horizontal padding" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "4px", "$description": "Button radius (rounded)" },
    "md": { "$type": "dimension", "$value": "8px", "$description": "Card radius (rounded-lg)" },
    "full": { "$type": "dimension", "$value": "9999px", "$description": "Pill radius (rounded-full)" }
  },
  "fontSize": {
    "xs": { "$type": "dimension", "$value": "12px", "$description": "Helper / chip text" },
    "sm": { "$type": "dimension", "$value": "14px", "$description": "Body text" },
    "base": { "$type": "dimension", "$value": "16px", "$description": "Default body copy" }
  }
}
